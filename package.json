{
  "name": "dual-reasoning",
  "version": "1.0.0",
  "description": "Local AI Coding Engine",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "node build.js",
    "build:full": "node scripts/build-full.js",
    "build:full:clean": "node scripts/build-full.js --force",
    "build:full:win": "node scripts/build-full.js win32-x64",
    "build:full:mac": "node scripts/build-full.js darwin-arm64",
    "build:full:mac-intel": "node scripts/build-full.js darwin-x64",
    "build:full:linux": "node scripts/build-full.js linux-x64",
    "build:full:linux-arm": "node scripts/build-full.js linux-arm64",
    "master:sync": "node scripts/master-sync.js",
    "master:update": "node scripts/master-sync.js --update",
    "master:check": "node scripts/master-sync.js --check",
    "build:all": "node build.all.js",
    "build:lite": "node scripts/build-lite.js",
    "build:lite:win": "node scripts/build-lite.js win32-x64",
    "build:lite:mac": "node scripts/build-lite.js darwin-arm64",
    "build:lite:mac-intel": "node scripts/build-lite.js darwin-x64",
    "build:lite:linux": "node scripts/build-lite.js linux-x64",
    "build:lite:linux-arm": "node scripts/build-lite.js linux-arm64",
    "start": "node dist/server.js",
    "db:setup": "node scripts/setup-db.js",
    "build:llamaarm64": "gh workflow run build-llamaarm64.yml"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.1",
    "@huggingface/transformers": "^3.0.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@omnimedia/omniclip": "1.1.3",
    "@types/archiver": "^7.0.0",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "argon2-browser": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "camofox-browser": "1.5.0",
    "dotenv": "^16.4.5",
    "duckdb": "1.4.4",
    "duckdb-async": "^1.4.2",
    "fastify": "^5.0.0",
    "kdbxweb": "^2.1.1",
    "kokoro-js": "^1.2.1",
    "mammoth": "^1.12.0",
    "ninja": "^3.0.8",
    "node-datachannel": "^0.10.1",
    "node-html-parser": "^7.1.0",
    "onnxruntime-node": "^1.17.3",
    "openai": "^4.71.1",
    "pdfjs-dist": "^5.6.205",
    "posthog-js": "^1.372.6",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "vss": "^0.1.1",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "camofox-browser": "1.5.0",
    "esbuild": "^0.27.3",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "duckdb-async": {
      "duckdb": "1.4.4"
    },
    "node-gyp": "^10.3.1",
    "tree-sitter-javascript": {
      "tree-sitter": "$tree-sitter"
    },
    "tree-sitter-typescript": {
      "tree-sitter": "$tree-sitter"
    }
  }
}